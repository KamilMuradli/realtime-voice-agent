# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit secrets.

# STT (OpenAI-compatible endpoint)
STT_BASE_URL=https://your-stt-endpoint.example.com
STT_API_KEY=

# LLM — Primary (OpenAI-compatible)
LLM_BASE_URL=https://your-llm-endpoint.example.com
LLM_API_KEY=

# LLM — Secondary (OpenAI-compatible)
GEMMA_SC_BASE_URL=https://your-secondary-llm.example.com
GEMMA_SC_API_KEY=

# LLM — GPT (OpenAI-compatible)
GPT_BASE_URL=https://your-gpt-endpoint.example.com
GPT_API_KEY=

# TTS — OpenAI-compatible REST
TTS_BASE_URL=https://your-tts-endpoint.example.com
TTS_API_KEY=

# TTS — Cognitive Services Speech REST
AZURE_SPEECH_REGION=eastus
AZURE_SPEECH_KEY=

# TTS — ElevenLabs
ELEVENLABS_API_KEY=
